@startuml

skinparam componentStyle uml2
skinparam linetype ortho
skinparam backgroundColor #FFFAF0
skinparam classBackgroundColor #E6E6FA
skinparam classBorderColor #483D8B
skinparam noteBackgroundColor #FFF0F5
skinparam noteBorderColor #FF69B4

class smooth_3d {
  **X**: NdArray - Input data for X axis
  **Y**: NdArray - Input data for Y axis
  **input_names**: Sequence[str] - Names for input dimensions
  **output_name**: str - Name for output dimension
  **rescaler**: DataRescaler - For scaling data values
  **ax**: Sequence[Axes] - Matplotlib axes for plotting
  **zslices**: NdArray - Z-values for 3D slices
  **xlims**: Tuple[float, float] - X-axis limits
  **ylims**: Tuple[float, float] - Y-axis limits
  **zlims**: Tuple[float, float] - Z-axis limits
  **vlims**: Tuple[float, float] - Value limits for colormap
  **draw_colorbar**: Optional[bool] - Whether to display colorbar
  **cube_edge_props**: Dict - Properties for 3D cube edges
  **projection_angle**: float - Angle for 3D projection
  **projection_diag_coef**: float - Coefficient for projection
  **colorbar_position**: Tuple[float, float] - Colorbar placement
  **colorbar_size**: Tuple[float, float] - Colorbar dimensions
  **xaxis_labelpad**: int - Padding for X-axis label
  **yaxis_labelpad**: int - Padding for Y-axis label
  **zaxis_labelpad**: int - Padding for Z-axis label
}

class smooth_2d {
  **X**: NdArray - Input data for X axis
  **Y**: NdArray - Input data for Y axis
  **input_names**: Sequence[str] - Names for input dimensions
  **output_name**: str - Name for output dimension
  **rescaler**: DataRescaler - For scaling data values
  **ax**: Axes - Matplotlib axes for plotting
  **zslice**: Optional[NdArray] - Z-value for current 2D slice
  **title**: Optional[str] - Plot title
  **xtitle**: Optional[str] - X-axis title
  **ytitle**: Optional[str] - Y-axis title
  **xlims**: Tuple[float, float] - X-axis limits
  **ylims**: Tuple[float, float] - Y-axis limits
  **vlims**: Tuple[float, float] - Value limits for colormap
  **draw_xlabel**: bool - Whether to draw X-axis label
  **draw_ylabel**: bool - Whether to draw Y-axis label
  **draw_colorbar**: bool - Whether to display colorbar
  **draw_colorbar_label**: bool - Whether to label colorbar
}

class knn_grid {
  **x**: NdArray - Input X coordinates
  **y**: NdArray - Input Y coordinates
  **xlims**: Tuple[float, float] - X-axis limits
  **ylims**: Tuple[float, float] - Y-axis limits
  **zslice**: Optional[NdArray] - Z-value for 3D data
  **is_density_plot**: bool - Whether to plot density
  **grid_resolution**: int - Resolution of output grid
}

class heatmap {
  **ax**: Axes - Matplotlib axes for plotting
  **xy_grid**: NdArray - Grid of X-Y coordinates
  **output_values**: NdArray - Values to be plotted
  **vlims**: Tuple[float, float] - Value limits for colormap
  **contours**: int - Number of contour lines
  **opacities**: Optional[NdArray] - Opacity values for plot
  **axtransform**: Optional[Transform] - Custom axis transform
  **cmap**: str - Colormap name
  **bad_color**: str - Color for invalid data
}

class colorbar {
  **ax**: Axes - Matplotlib axes for colorbar
  **im**: AxesImage - Image to create colorbar from
  **rescaler**: DataRescaler - For scaling colorbar values
  **vlims**: Tuple[float, float] - Value limits for colorbar
  **label**: Optional[str] - Colorbar label
  **position**: Tuple[float, float] - Colorbar placement
  **size**: Tuple[float, float] - Colorbar dimensions
  **orientation**: str - Vertical or horizontal orientation
  **label_position**: str - Position of colorbar label
  **label_props**: Dict - Properties for label styling
  **tick_props**: Dict - Properties for tick styling
}

smooth_3d -down-> smooth_2d
smooth_2d -down-> knn_grid
smooth_2d -down-> heatmap
smooth_2d -down-> colorbar

note right of smooth_3d
  Orchestrates the 3D plotting process,
  creating multiple 2D slices and
  arranging them in a 3D projection
end note

note right of smooth_2d
  Creates a 2D heatmap representation
  of a slice of 3D data
end note

note right of knn_grid
  Prepares data for plotting using
  K-Nearest Neighbors algorithm
end note

note right of heatmap
  Generates a heatmap visualization
  of the prepared data
end note

note right of colorbar
  Adds a colorbar to the plot,
  showing the scale of values
end note

@enduml
